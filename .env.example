# =============================================================================
# AppBoletim — variáveis de ambiente
# Copie este arquivo para ".env" (nunca commite o ".env") e preencha os valores.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
# URL pública onde o app roda (usada para montar o redirect_uri do OAuth e links absolutos)
APP_BASE_URL=http://localhost:3000

# Chave usada para assinar/criptografar o cookie de sessão (JWT via jose).
# Gere uma nova em produção, por exemplo com: openssl rand -base64 32
SESSION_SECRET=troque-por-uma-chave-secreta-com-pelo-menos-32-caracteres

# -----------------------------------------------------------------------------
# Layers Education — SSO (OAuth2 Authorization Code)
# -----------------------------------------------------------------------------
# A documentação pública de developers.layers.education não expõe os paths
# exatos de /authorize, /token e /userinfo fora do portal de parceiros
# cadastrados (ver README > "Status da integração Layers"). Por isso nenhum
# endpoint vem hardcoded no código — preencha com os valores fornecidos pela
# Layers ao cadastrar o app como parceiro/desenvolvedor.
LAYERS_CLIENT_ID=
LAYERS_CLIENT_SECRET=
# Deve ser cadastrada como redirect URI permitida no app registrado na Layers.
LAYERS_REDIRECT_URI=http://localhost:3000/api/auth/layers/callback

# TODO: confirmar os 3 endpoints reais com o time da Layers (suporte@layers.education)
# ou na documentação de parceiro. O candidato observado publicamente para o portal
# de identidade é https://id.layers.digital — NÃO CONFIRMADO, ajuste antes de produção.
LAYERS_AUTH_URL=https://id.layers.digital/oauth2/authorize
LAYERS_TOKEN_URL=https://id.layers.digital/oauth2/token
LAYERS_USERINFO_URL=https://id.layers.digital/oauth2/userinfo

LAYERS_SCOPES=openid profile email

# Nome do campo no JSON de /userinfo que contém o RA (matrícula) do aluno.
# Se não confirmado, o app tenta, nessa ordem: ra, registration_number, external_id, cpf, email.
LAYERS_STUDENT_ID_FIELD=ra

# IdP falso SOMENTE para desenvolvimento local, sem depender de credenciais reais
# da Layers. NUNCA habilite em produção. Veja README > "Rodando sem credenciais reais".
LAYERS_FAKE_IDP=true

# -----------------------------------------------------------------------------
# TOTVS RM — Web Service wsConsultaSQL (IwsConsultaSQL)
# -----------------------------------------------------------------------------
# mock = usa dados fictícios (padrão, não depende de rede/credenciais reais)
# real = chama o webservice SOAP real definido abaixo
TOTVS_MODE=mock

TOTVS_BASE_URL=https://associacaoisraelita138614.rm.cloudtotvs.com.br:8051/wsConsultaSQL/IwsConsultaSQL
# Usuário técnico de integração (NUNCA o usuário/senha do aluno).
# Peça as credenciais reais para quem administra o TOTVS na escola — não
# commite valores reais aqui, preencha apenas no seu ".env" local.
TOTVS_USERNAME=
TOTVS_PASSWORD=

# Nome da operação SOAP e SOAPAction — confirmados em teste real contra o
# servidor da escola. Ajustáveis sem mexer em código caso mudem em outro ambiente.
TOTVS_SOAP_OPERATION=RealizarConsultaSQL
TOTVS_SOAP_ACTION=http://www.totvs.com/IwsConsultaSQL/RealizarConsultaSQL
TOTVS_SOAP_NAMESPACE=http://www.totvs.com/

# Parâmetros fixos da consulta
TOTVS_COD_COLIGADA=1
TOTVS_COD_SISTEMA=G
TOTVS_SENTENCA_NOTAS=CUBO.07

# Parâmetros de negócio da sentença (RA real virá futuramente da sessão Layers)
TOTVS_FILIAL=1
TOTVS_PERIODO_LETIVO=2026
TOTVS_RA_PADRAO=20131249

# Média mínima usada para destacar disciplinas abaixo do esperado (a sentença
# CUBO.07 não devolve esse valor, então é fixo via env — confirmar com a escola
# se varia por série).
TOTVS_MEDIA_MINIMA=7.0

# O servidor TOTVS deste ambiente usa certificado autoassinado.
TOTVS_IGNORE_SELF_SIGNED_CERT=true

TOTVS_TIMEOUT_MS=15000
